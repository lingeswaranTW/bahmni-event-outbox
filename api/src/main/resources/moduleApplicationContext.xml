<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
       http://www.springframework.org/schema/context
       http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <context:component-scan base-package="org.bahmni.module.eventoutbox"/>

    <bean id="outboxEventDao" class="org.bahmni.module.eventoutbox.dao.impl.OutboxEventDaoImpl">
        <property name="sessionFactory">
            <ref bean="sessionFactory"/>
        </property>
    </bean>

    <bean id="outboxEventServiceTarget" class="org.bahmni.module.eventoutbox.service.impl.OutboxEventServiceImpl">
        <property name="outboxEventDao">
            <ref bean="outboxEventDao"/>
        </property>
    </bean>

    <bean id="outboxEventService" class="org.springframework.transaction.interceptor.TransactionProxyFactoryBean">
        <property name="transactionManager">
            <ref bean="transactionManager"/>
        </property>
        <property name="target">
            <ref bean="outboxEventServiceTarget"/>
        </property>
        <property name="transactionAttributes">
            <props>
                <prop key="save">PROPAGATION_REQUIRED</prop>
            </props>
        </property>
    </bean>

</beans>
